    <Folder Name="Gameplay" Guid="e4b7dfcf-a325-4a33-a1e9-e6e188c8274c">
    <ComponentTemplate Name="PickableGatherer" Description="Behavior that makes a creature pick up certain items based on categories and probabilities" Guid="78692df4-7e31-4ed2-9ba7-7cbe22c31850" InheritanceParent="6cc7245f-56f2-4a77-a3db-5f628b6369b3">
