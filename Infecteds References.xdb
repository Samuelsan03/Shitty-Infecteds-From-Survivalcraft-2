    <ComponentTemplate Name="InfectedWithPoison" Description="Afecta a la criatura con veneno, reduce su velocidad y la hace vomitar periodicamente" Guid="5a97d777-b5aa-45fc-9442-9f47addf7988" InheritanceParent="b05700ed-7e4e-4679-98f5-b597f421496b">
