</ComponentTemplate>

<ComponentTemplate Name="CreatureFlu" Description="Afecta a la criatura con gripa, provocando tos y estornudos periodicos que infligen danio" Guid="13c23935-cef8-4284-9177-e890dd9c667d" InheritanceParent="b05700ed-7e4e-4679-98f5-b597f421496b">
