				<Parameter Name="Clothes" Description="衣物, 0 to infinity" Guid="0c487546-710e-436a-9f3b-0c4bf567da46" Value="0" Type="float" />
				<Parameter Name="Electrics" Description="电路元件, 0 to infinity" Guid="f87f7dc6-a3fc-4413-852c-049a656ec0e3" Value="0" Type="float" />
