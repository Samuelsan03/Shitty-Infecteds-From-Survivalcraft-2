    <ComponentTemplate Name="NewChaseBehavior" Description="Comportamiento que hace que una criatura persiga a intrusos. Versión compatible con NewHerdBehavior para proteger al jugador." Guid="ac087cf3-2de5-4e76-9167-95e9754b69fd" InheritanceParent="6cc7245f-56f2-4a77-a3db-5f628b6369b3">
  <Parameter Name="Class" Guid="fcd46c9e-6959-4c0b-a0f7-c8cceadf991e" Value="Game.ComponentNewChaseBehavior" Type="string" />
  <Parameter Name="ChaseWhenAttackedProbability" Description="Probabilidad de que la criatura persiga cuando es atacada" Guid="98c97dcb-0a27-4451-bb50-8b3102dec2fe" Value="1" Type="float" />
  <Parameter Name="NightChaseTime" Description="Tiempo de persecución cuando la criatura empieza a perseguir durante la noche, en segundos" Guid="81c354c4-d99a-4211-b87e-0b5c58419989" Value="10" Type="float" />
  <Parameter Name="DayChaseRange" Description="Rango cuando la criatura empieza a perseguir durante el día" Guid="67968332-40f5-4909-9a00-112419e1f220" Value="1.5" Type="float" />
  <Parameter Name="ChaseOnTouchProbability" Description="Probabilidad de que la criatura persiga si es tocada por una criatura de AutoChaseMask" Guid="7d478b56-bcda-48de-8151-6debe34307a3" Value="1" Type="float" />
  <Parameter Name="DayChaseTime" Description="Tiempo de persecución cuando la criatura empieza a perseguir durante el día, en segundos" Guid="eff4140c-f9b3-4b1e-847a-e6d05b859e07" Value="10" Type="float" />
  <Parameter Name="NightChaseRange" Description="Rango cuando la criatura empieza a perseguir durante la noche" Guid="3473bace-e628-4028-be54-8123837f7d94" Value="1.5" Type="float" />
  <Parameter Name="AutoChaseMask" Description="Categorías de criaturas a perseguir" Guid="c74e40cf-1c82-4997-a230-2b8cea61eb91" Value="LandOther, Bird" Type="Game.CreatureCategory" />
  <Parameter Name="ChaseNonPlayerProbability" Description="Probabilidad de que la criatura persiga a un objetivo no jugador cuando está en rango, de 0 a 1" Guid="54db5623-3f54-4274-9b89-4d72d91acc9b" Value="0" Type="float" />
  <Parameter Name="InvokeLightningOnHit" Description="Si es verdadero, al golpear cuerpo a cuerpo invoca un rayo sobre la víctima" Guid="f4a0ddb7-336d-4468-998c-eab878df6130" Value="false" Type="bool" />
  <Parameter Name="ExplodeOnHit" Description="Si es verdadero, al golpear cuerpo a cuerpo crea una explosión normal en la víctima" Guid="cbbaa8e2-35e8-4e44-916e-4818b983f1f2" Value="false" Type="bool" />
  <Parameter Name="DestroyBlocksWhenStuck" Description="Si es verdadero, al estar atascado rompe 2 bloques en la dirección de la mirada" Guid="f05f7c35-29b8-42fa-9ee4-4c70600ab7df" Value="false" Type="bool" />
  <Parameter Name="PushVictimOnHit" Description="Si es verdadero, al golpear a su presa la empuja haciéndola salir volando" Guid="3f86b7ff-4e9d-4602-a6af-61b4b1db56cb" Value="false" Type="bool" />
</ComponentTemplate>

<ComponentTemplate Name="NewHerdBehavior" Description="Comportamiento que hace que una criatura permanezca cerca de criaturas similares o siga al jugador si HerdName es 'player'. Las criaturas con HerdName='player' protegerán al jugador." Guid="e8f5a293-55ce-4a36-acf6-f215e5f9c93f" InheritanceParent="6cc7245f-56f2-4a77-a3db-5f628b6369b3">
  <Parameter Name="AutoNearbyCreaturesHelp" Description="Si es verdadero, cuando una criatura cercana de la misma manada es atacada, atacará automáticamente a su atacante" Guid="5fc7b6ec-bb8a-4416-9f03-f09352a394e9" Value="False" Type="bool" />
  <Parameter Name="HerdName" Description="Identificador usado para encontrar miembros de la misma especie para agruparse. Usa 'player' para que la criatura siga y proteja al jugador." Guid="7212b035-38a0-4aec-9bf6-509ac1fb095b" Value="KaalusGlitch" Type="string" />
  <Parameter Name="Class" Guid="720ae469-7471-4274-aded-91b41177a17c" Value="Game.ComponentNewHerdBehavior" Type="string" />
  <Parameter Name="HerdingRange" Description="Distancia máxima para buscar miembros de la manada al determinar el centro de la manada" Guid="fe38a859-622e-4a97-b9ba-7262ebdae592" Value="32" Type="float" />
</ComponentTemplate>

    <ComponentTemplate Name="ZombieHerdBehavior" Description="Comportamiento de manada para zombis. Agrupa a los zombis por nombre de manada y les permite llamar ayuda entre compañeros" Guid="5a8d1636-1ad9-4344-8c36-a39d9bb2524d" InheritanceParent="6cc7245f-56f2-4a77-a3db-5f628b6369b3">
  <Parameter Name="Class" Guid="1317caed-e16e-4a82-8c2d-fbf482c81596" Value="Game.ComponentZombieHerdBehavior" Type="string"/>
  <Parameter Name="HerdName" Description="Nombre de la manada. Los zombis con el mismo nombre se consideran compañeros y no se atacan entre sí" Guid="eae47118-785d-4ce3-aea4-788abb74b106" Value="Zombie" Type="string"/>
  <Parameter Name="HerdingRange" Description="Rango en metros dentro del cual se considera que un compañero forma parte de la manada para calcular el centro del grupo" Guid="085f8a84-9fb8-470b-92dd-ca64c24433df" Value="16" Type="float"/>
  <Parameter Name="AutoNearbyCreaturesHelp" Description="Si es verdadero, el zombi llamará a otros compañeros de manada cuando sea atacado" Guid="82144d41-edae-46d6-831d-773d6e1f4a3a" Value="true" Type="bool"/>
</ComponentTemplate>

<ComponentTemplate Name="ZombieChaseBehavior" Description="Comportamiento de persecución para zombis. Persigue a cualquier criatura excepto a los miembros de su misma manada" Guid="67f04819-c0f2-47f4-bde2-436dcdb8132b" InheritanceParent="6cc7245f-56f2-4a77-a3db-5f628b6369b3">
  <Parameter Name="Class" Guid="37f4502b-de54-4825-b823-6b52d16a33cf" Value="Game.ComponentZombieChaseBehavior" Type="string"/>
  <Parameter Name="ChaseRangeDay" Description="Rango en metros durante el día en el que el zombi detecta y comienza a perseguir a su objetivo" Guid="e1105781-fa5d-48fc-92c4-0e8e96419e2c" Value="15" Type="float"/>
  <Parameter Name="ChaseRangeNight" Description="Rango en metros durante la noche en el que el zombi detecta y comienza a perseguir a su objetivo" Guid="26f4665c-fb55-4bf1-a1fd-6edbf520a4a4" Value="20" Type="float"/>
  <Parameter Name="ChaseTimeDay" Description="Duración en segundos que el zombi perseguirá a su objetivo durante el día" Guid="ceb8d649-6e5c-4bdd-90bb-08c593af6da9" Value="15" Type="float"/>
  <Parameter Name="ChaseTimeNight" Description="Duración en segundos que el zombi perseguirá a su objetivo durante la noche" Guid="33b8c95e-e38a-4192-a2bf-c38ee6fb766e" Value="20" Type="float"/>
  <Parameter Name="ChaseNonPlayerProbability" Description="Probabilidad de 0 a 1 de que el zombi persiga a una criatura no jugador cuando está dentro del rango de persecución" Guid="526baa21-2b07-4e77-9265-2ee22c185b14" Value="1" Type="float"/>
  <Parameter Name="AutoChaseMask" Description="Categorías de criaturas no jugador que este zombi puede perseguir automáticamente (se combina con la probabilidad de persecución)" Guid="a1b2c3d4-e5f6-7890-abcd-ef1234567890" Value="LandPredator" Type="Game.CreatureCategory"/>
  <Parameter Name="ChaseWhenAttackedProbability" Description="Probabilidad de 0 a 1 de que el zombi persiga al agresor cuando es atacado. Los zombis siempre persiguen a quien los ataca" Guid="a02cdac7-1a4c-4470-a7f8-ae593fab7250" Value="1" Type="float"/>
  <Parameter Name="ChaseOnTouchProbability" Description="Probabilidad de 0 a 1 de que el zombi persiga a una criatura que lo toca físicamente" Guid="2c1554a1-c319-48d2-840c-61c921af9176" Value="0.5" Type="float"/>
  <Parameter Name="AttacksPlayer" Description="Si es verdadero, el zombi atacará a los jugadores. Los zombis atacan a los jugadores por defecto" Guid="24165013-d2bf-4087-afbe-7208dab36b0e" Value="true" Type="bool"/>
  <Parameter Name="AttacksNonPlayerCreature" Description="Si es verdadero, el zombi atacará a otras criaturas no jugadores. Los zombis atacan a todas las criaturas excepto a los de su manada" Guid="508622b2-7a21-4951-91a7-6081177fa522" Value="true" Type="bool"/>
  <Parameter Name="MoreAggressiveOnGreenNight" Description="Si es verdadero, el zombi se vuelve extremadamente agresivo y persigue al jugador hasta la muerte durante la Noche Verde" Guid="50bfb787-bf96-4b66-9ae0-d44ceddd6ac0" Value="false" Type="bool"/>
</ComponentTemplate>

