    <ComponentTemplate Name="Teleport" Description="Permite a la criatura teletransportarse cerca de su objetivo" Guid="6ff6930a-6379-43e1-bac2-1dcca9a87627" InheritanceParent="6cc7245f-56f2-4a77-a3db-5f628b6369b3">
