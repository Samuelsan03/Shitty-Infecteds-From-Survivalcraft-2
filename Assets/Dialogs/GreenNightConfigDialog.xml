<CanvasWidget xmlns="runtime-namespace:Game">

  <CanvasWidget Size="600, 480" ClampToBounds="true" HorizontalAlignment="Center" VerticalAlignment="Center">
    <BevelledRectangleWidget Style="{Styles/DialogArea}" />

    <StackPanelWidget Direction="Vertical" HorizontalAlignment="Center" Margin="20, 10">

      <LabelWidget Text="Configuración de Noche Verde" HorizontalAlignment="Center" Margin="0, 10" FontScale="1.1" Color="0, 255, 94" DropShadow="true" />

      <LabelWidget Text="Escoga los días que ocurrirá la noche verde" HorizontalAlignment="Center" Margin="0, 8" Color="200, 200, 200" />

      <StackPanelWidget Direction="Horizontal" HorizontalAlignment="Center" Margin="0, 8">
        <LabelWidget Text="Días que te quedarán de vida:" Color="180, 180, 180" VerticalAlignment="Center" Margin="0, 0, 10, 0" />
        <BevelledButtonWidget Name="GreenNightConfig.DaysButton" Text="4 días" Size="160, 60" />
      </StackPanelWidget>

      <CanvasWidget Size="470, 80" HorizontalAlignment="Center" Margin="0, 12">
        <ScrollPanelWidget Direction="Vertical">
          <LabelWidget Name="GreenNightConfig.Description" Text="" Color="150, 150, 150" FontScale="0.75" />
        </ScrollPanelWidget>
      </CanvasWidget>

      <LabelWidget Text="¿Qué Tan Rápido Quieres Morir?" HorizontalAlignment="Center" Margin="0, 12, 0, 6" FontScale="0.9" Color="200, 150, 150" DropShadow="true" />

      <BevelledButtonWidget Name="GreenNightConfig.DifficultyButton" Text="" Size="300, 60" HorizontalAlignment="Center" />

      <UniformSpacingPanelWidget Direction="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0, 12">
        <BevelledButtonWidget Size="160, 60" HorizontalAlignment="Center" Name="GreenNightConfig.OkButton" Text="Aceptar" />
        <BevelledButtonWidget Size="160, 60" HorizontalAlignment="Center" Name="GreenNightConfig.CancelButton" Text="Cancelar" />
      </UniformSpacingPanelWidget>

    </StackPanelWidget>

  </CanvasWidget>
</CanvasWidget>
