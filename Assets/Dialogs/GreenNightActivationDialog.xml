<CanvasWidget xmlns="runtime-namespace:Game">

  <CanvasWidget Size="600, 420" ClampToBounds="true" HorizontalAlignment="Center" VerticalAlignment="Center">
    <BevelledRectangleWidget Style="{Styles/DialogArea}" />

    <StackPanelWidget Direction="Vertical" HorizontalAlignment="Center" Margin="10, 0">

      <StackPanelWidget Direction="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
        <LabelWidget Text="Administración Noche Verde" HorizontalAlignment="Center" Margin="0, 15" Color="80, 220, 80" />
      </StackPanelWidget>

      <CanvasWidget Size="Infinity, Infinity">
        <StackPanelWidget Direction="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">

          <StackPanelWidget Margin="0, 10" HorizontalAlignment="Center">
            <CheckboxWidget Name="GreenNightActivationDialog.ActivateCheckbox" Text="Activar Noche Verde" Color="255, 255, 255" IsAutoCheckingEnabled="true" CheckboxSize="32, 32" TickSubtexture="{Textures/Atlas/Tick}" />
          </StackPanelWidget>

          <CanvasWidget Size="520, 180" HorizontalAlignment="Center">
            <ScrollPanelWidget Direction="Vertical">
              <LabelWidget Name="GreenNightActivationDialog.Description" Text="El mundo mantiene su equilibrio habitual con rangos de percepción limitados y persecuciones breves." Color="255, 165, 0" HorizontalAlignment="Center" Margin="10, 5" />
            </ScrollPanelWidget>
          </CanvasWidget>

        </StackPanelWidget>
      </CanvasWidget>

      <UniformSpacingPanelWidget Direction="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10, 15">
        <BevelledButtonWidget Style="{Styles/ButtonStyle_160x60}" HorizontalAlignment="Center" Name="GreenNightActivationDialog.CancelButton" Text="Cancelar" />
        <BevelledButtonWidget Style="{Styles/ButtonStyle_160x60}" HorizontalAlignment="Center" Name="GreenNightActivationDialog.OkButton" Text="Aceptar" />
      </UniformSpacingPanelWidget>

    </StackPanelWidget>

  </CanvasWidget>
</CanvasWidget>
